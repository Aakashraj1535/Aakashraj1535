<svg width="1200" height="260" viewBox="0 0 1200 260" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0D1117"/>
      <stop offset="55%" stop-color="#151A2E"/>
      <stop offset="100%" stop-color="#1B1440"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#2563EB"/>
      <stop offset="100%" stop-color="#8A63F5"/>
    </linearGradient>
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="10" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <rect width="1200" height="260" fill="url(#bg)"/>

  <!-- subtle circuit-style grid lines -->
  <g stroke="#2563EB" stroke-opacity="0.12" stroke-width="1">
    <line x1="0" y1="60" x2="1200" y2="60"/>
    <line x1="0" y1="130" x2="1200" y2="130"/>
    <line x1="0" y1="200" x2="1200" y2="200"/>
    <line x1="150" y1="0" x2="150" y2="260"/>
    <line x1="450" y1="0" x2="450" y2="260"/>
    <line x1="750" y1="0" x2="750" y2="260"/>
    <line x1="1050" y1="0" x2="1050" y2="260"/>
  </g>

  <!-- glowing accent nodes -->
  <circle cx="150" cy="60" r="4" fill="#8A63F5" filter="url(#glow)"/>
  <circle cx="750" cy="130" r="4" fill="#2563EB" filter="url(#glow)"/>
  <circle cx="1050" cy="200" r="4" fill="#8A63F5" filter="url(#glow)"/>

  <rect x="60" y="60" width="6" height="140" fill="url(#accent)"/>

  <text x="100" y="120" font-family="Segoe UI, Helvetica, Arial, sans-serif" font-size="46" font-weight="700" fill="#F0F3F9">
    Aakash Raj
  </text>
  <text x="100" y="160" font-family="Segoe UI, Helvetica, Arial, sans-serif" font-size="22" fill="#8A93A8">
    Full-Stack Developer &#8226; AI / Agentic Systems Engineer
  </text>

  <rect x="100" y="185" width="230" height="2" fill="url(#accent)"/>
</svg>
